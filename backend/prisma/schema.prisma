generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PolicyType {
  MANAGED
  INLINE
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  isRoot       Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groupMemberships UserGroupMembership[]
  policyAttachments UserPolicyAttachment[]
  boundary          UserBoundary?
}

model Group {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members           UserGroupMembership[]
  policyAttachments GroupPolicyAttachment[]
}

model Policy {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  type        PolicyType
  statements  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userAttachments  UserPolicyAttachment[]
  groupAttachments GroupPolicyAttachment[]
  boundaries       UserBoundary[]
}

model UserGroupMembership {
  userId  String
  groupId String
  addedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

model UserPolicyAttachment {
  userId     String
  policyId   String
  attachedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@id([userId, policyId])
  @@index([userId])
  @@index([policyId])
}

model GroupPolicyAttachment {
  groupId    String
  policyId   String
  attachedAt DateTime @default(now())

  group  Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@id([groupId, policyId])
  @@index([groupId])
  @@index([policyId])
}

model UserBoundary {
  userId   String   @id
  policyId String
  setAt    DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  policy Policy @relation(fields: [policyId], references: [id])

  @@index([policyId])
}
